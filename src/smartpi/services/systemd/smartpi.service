[Unit]
Description=Smart Pi Interactive Projection
After=network.target graphical.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/rashbarrypi
Environment=DISPLAY=:0
ExecStart=/usr/bin/python3 -m smartpi.cli run --fullscreen
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
